@page "/"
@page "/{url}"
@layout PublicLayout
@inject IHttpClientFactory HttpClientFactory

@* Använd för att hämta API:ts URL från appsettings.json, eftersom bilderna ligger på API-servern *@
@inject IConfiguration Config 
@* Prerendering avstängd för att undvika dubbel besöksregistrering *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@if (contentBlocks == null)                                                              
{                                                                                          
    <p>Laddar...</p>                                                                       
}                                                                                          
else                                                                                       
{    
    @* Hero visas bara om det finns innehåll *@
    @if (heroBlocks.Any())
    {
        @* Hämtar första hero-blocket för den sidan, brukar bara ha en hero. *@
        var hero = heroBlocks.First();
        var heroImageUrl = $"{Config["ApiUrl"]}{hero.Image}";
        <div class="row mb-4">
            <div class="col-12">
                <div class="p-5 rounded-3 text-white"
                     style="background-image: url('@heroImageUrl');
                          background-size: cover;
                          background-position: center;
                          min-height: 300px;">
                    <h1 class="display-4 text-white">@hero.Title</h1>
                    @if (!string.IsNullOrEmpty(hero.Text))
                    {
                        <p class="lead">@hero.Text</p>
                    }
                </div>
            </div>
        </div>
    }
    
    <div class="row"> @* Visar alltid main och sidebar *@
        <div class="col-md-8">
            <ContentSection Blocks="mainBlocks" Section="main" />
        </div>
        <div class="col-md-4">
            <ContentSection Blocks="sidebarBlocks" Section="sidebar" />
        </div>
    </div>
  
    @* Footer visas bara om det finns innehåll *@
    @if (footerBlocks.Any())
    {
        <div class="row mt-4 pt-3 border-top">
            <div class="col-12">
                <ContentSection Blocks="footerBlocks" Section="footer" />
            </div>
        </div>
    }                       
}

@code {
    [Parameter] 
    public string Url { get; set; } = "";

    private HttpClient client = default!;

    private List<ContentBlockModel>? contentBlocks;
    private List<PageModel>? pages;
    private PageModel? currentPage;
    
    // Filtrerar contentBlocks per sektion. Returnerar tom lista om contentBlocks är null.
    private List<ContentBlockModel> heroBlocks => contentBlocks?.Where(b => b.Section == "hero").ToList() ?? new();
    private List<ContentBlockModel> mainBlocks => contentBlocks?.Where(b => b.Section == "main").ToList() ?? new();
    private List<ContentBlockModel> sidebarBlocks => contentBlocks?.Where(b => b.Section == "sidebar").ToList() ?? new();
    private List<ContentBlockModel> footerBlocks => contentBlocks?.Where(b => b.Section == "footer").ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        client = HttpClientFactory.CreateClient("Api");
        pages = await client.GetFromJsonAsync<List<PageModel>>("api/pages");

        // Ingen URL, hämtar alla sidor, ta första som startsida
        if (string.IsNullOrEmpty(Url))
        {
            currentPage = pages?.FirstOrDefault();
        }
        else // Annars hämtar sidan med den angivna URL:en
        {
            currentPage = await client.GetFromJsonAsync<PageModel>($"api/pages/url/{Url}");
        }
        
        // Hämta contentBlocks för den sidan
        if (currentPage != null)
        {
            contentBlocks = await client.GetFromJsonAsync<List<ContentBlockModel>>($"api/contentblocks/page/{currentPage.Id}");
        }

        // Registrera besök på aktuell sida
        if (currentPage != null)
        {
            await client.PostAsJsonAsync("api/visits", new { PageId = currentPage.Id });
        }
    }
}