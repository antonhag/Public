@page "/"
@page "/{url}"
@inject IHttpClientFactory HttpClientFactory
@* Prerendering avstängd för att undvika dubbel besöksregistrering *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<nav>                                                                                    
    @if (menuItems != null)                                                                
    {                                                                                      
        @foreach (var item in menuItems.OrderBy(m => m.Order))                             
        {                                   
            <a href="/@(pages?.FirstOrDefault(p => p.Id ==                                 
                                                   item.PageId)?.Url)">@item.MenuTitle</a>         
        }                                                                                  
    }                                       
</nav>     

@if (contentBlocks == null)                                                              
{                                                                                          
    <p>Laddar...</p>                                                                       
}                                                                                          
else                                                                                       
{                                                                                          
    <div class="main-content">
        <ContentSection Blocks="mainBlocks" />
    </div>
    <div class="sidebar-content">
        <ContentSection Blocks="sidebarBlocks" />
    </div>
    <div class="footer-content">
        <ContentSection Blocks="footerBlocks" />   
    </div>                        
}

@code {
    [Parameter] 
    public string Url { get; set; } = "";

    private HttpClient client = default!;

    private List<MenuItemModel>? menuItems;
    private List<ContentBlockModel>? contentBlocks;
    private List<PageModel>? pages;
    private PageModel? currentPage;
    
    // Filtrerar contentBlocks per sektion. Returnerar tom lista om contentBlocks är null.
    private List<ContentBlockModel> mainBlocks => contentBlocks?.Where(b => b.Section == "main").ToList() ?? new();
    private List<ContentBlockModel> sidebarBlocks => contentBlocks?.Where(b => b.Section == "sidebar").ToList() ?? new();
    private List<ContentBlockModel> footerBlocks => contentBlocks?.Where(b => b.Section == "footer").ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        client = HttpClientFactory.CreateClient("Api");
        pages = await client.GetFromJsonAsync<List<PageModel>>("api/pages");
        menuItems = await client.GetFromJsonAsync<List<MenuItemModel>>("api/menuitems"); // Hämta menyn

        // Ingen URL, hämtar alla sidor, ta första som startsida
        if (string.IsNullOrEmpty(Url))
        {
            currentPage = pages?.FirstOrDefault();
        }
        else // Annars hämtar sidan med den angivna URL:en
        {
            currentPage = await client.GetFromJsonAsync<PageModel>($"api/pages/url/{Url}");
        }
        
        // Hämta contentBlocks för den sidan
        if (currentPage != null)
        {
            contentBlocks = await client.GetFromJsonAsync<List<ContentBlockModel>>($"api/contentblocks/page/{currentPage.Id}");
        }

        // Registrera besök på aktuell sida
        if (currentPage != null)
        {
            await client.PostAsJsonAsync("api/visits", new { PageId = currentPage.Id });
        }
    }
}