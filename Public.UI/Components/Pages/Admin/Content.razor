@page "/admin/content"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin,Editor")]
@inject IHttpClientFactory HttpClientFactory
@rendermode InteractiveServer

<h3 class="mb-4">Hantera innehåll</h3>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">@(editingId == null ? "Skapa nytt innehåll" : "Redigera innehåll")</h5> @* Dynamisk text beroende på skapa/redigera *@
    </div>
    <div class="card-body">
        <EditForm Model="newContent" OnValidSubmit="CreateContentAsync" FormName="CreateContent">
            <DataAnnotationsValidator/>
            <ValidationSummary class="text-danger"/>

            <div class="mb-3">
                <label class="form-label">Välj sida</label>
                <InputSelect @bind-Value="newContent.PageId" class="form-select">
                    <option value="0">-- Välj sida --</option>
                    @if (pages != null)
                    {
                        @foreach (var p in pages)
                        {
                            <option value="@p.Id">@p.Title</option>
                        }
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">Rubrik</label>
                <InputText @bind-Value="newContent.Title" class="form-control"/>
            </div>

            <div class="mb-3">
                <label class="form-label">Text</label>
                <InputTextArea @bind-Value="newContent.Text" class="form-control" rows="3"/>
            </div>

            <div class="mb-3">
                <label class="form-label">Bild</label>
                <InputFile OnChange="OnFileSelected" class="form-control"/>
            </div>

            <div class="mb-3">
                <label class="form-label">Länk</label>
                <InputText @bind-Value="newContent.Link" class="form-control"/>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Sektion</label>
                    <InputSelect @bind-Value="newContent.Section" class="form-select">
                        <option value="hero">Hero</option>
                        <option value="main">Main</option>
                        <option value="sidebar">Sidebar</option>
                        <option value="footer">Footer</option>
                    </InputSelect>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Ordning</label>
                    <InputNumber @bind-Value="newContent.Order" class="form-control"/>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">@(editingId == null ? "Skapa" : "Spara")</button> @* Dynamisk knapp beroende på skapa/redigera *@
            @if (editingId != null)
            {
                <button type="button" class="btn btn-danger ms-2" @onclick="CancelEdit">Avbryt</button>
            }
        </EditForm>
    </div>
</div>

@if (contentBlocks == null)
{
    <p>Laddar...</p>
}
else if (contentBlocks.Count == 0)
{
    <p>Inget innehåll ännu.</p>
}
else
{
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Befintligt innehåll</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead>
                    <tr>
                        <th>Sida</th>
                        <th>Rubrik</th>
                        <th>Text</th>
                        <th>Bild</th>
                        <th>Länk</th>
                        <th>Sektion</th>
                        <th>Ordning</th>
                        <th>Åtgärder</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var content in contentBlocks)
                    {
                        <tr>
                            <td>@(pages?.FirstOrDefault(p => p.Id == content.PageId)?.Title)</td>
                            <td>@content.Title</td>
                            <td>@content.Text</td>
                            <td>@content.Image</td>
                            <td>@content.Link</td>
                            <td>@content.Section</td>
                            <td>@content.Order</td>
                            <td>
                                <div class="d-grid gap-1">
                                    <button type="button" class="btn btn-warning btn-sm" @onclick="() => StartEdit(content)">Redigera</button>
                                    <button type="button" class="btn btn-danger btn-sm" @onclick="() => DeleteContentAsync(content.Id)">Ta bort</button>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private HttpClient client = default!;


    private List<ContentBlockModel>? contentBlocks;
    private List<PageModel>? pages;
    
    [SupplyParameterFromForm]
    private CreateContentBlockModel? newContent { get; set; } = new();

    private int? editingId;

    protected override async Task OnInitializedAsync()
    {
        client = HttpClientFactory.CreateClient("Api");
        await LoadContentAsync();
        pages = await client.GetFromJsonAsync<List<PageModel>>("api/pages");
    }
    
    private async Task LoadContentAsync()
    {
        contentBlocks = await client.GetFromJsonAsync<List<ContentBlockModel>>("api/contentblocks");
    }

    private async Task CreateContentAsync()
    {
        if (editingId == null)
        {
            await client.PostAsJsonAsync("api/contentblocks", newContent);
        }
        else
        {
            await client.PutAsJsonAsync($"api/contentblocks/{editingId}", newContent);
        }
        // nollställer formuläret
        newContent = new CreateContentBlockModel();
        editingId = null;
        await LoadContentAsync();
    }


    
    private async Task DeleteContentAsync(int id)
    {
        await client.DeleteAsync($"api/contentblocks/{id}");
        await LoadContentAsync();
    }
    
    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File; // Hämtar filen användaren valde
        var content = new MultipartFormDataContent(); // Skapar ett "paket" för att skicka filen via HTTP
        content.Add(new StreamContent(file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024)), "file", file.Name); // Lägger filen i paketet

        var response = await client.PostAsync("api/upload", content); // Skickar paketet till upload-endpointen
        newContent.Image = await response.Content.ReadAsStringAsync(); // Läser sökvägen som API:t returnerar och sparar den i modellen
    }
    
    private void StartEdit(ContentBlockModel content)      
    {                                                                                          
        editingId = content.Id;
        newContent = new CreateContentBlockModel
        {
            PageId = content.PageId,
            Title = content.Title,
            Text = content.Text,
            Image = content.Image,
            Link = content.Link,
            Section = content.Section,
            Order = content.Order             
        };
    }

    private void CancelEdit()
    {
        editingId = null;
        newContent = new CreateContentBlockModel();
    }
}