@page "/admin/pages"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject IHttpClientFactory HttpClientFactory
@rendermode InteractiveServer

<h3>Hantera sidor</h3>

<div class="card mb-4">
    <div class="card-header">
        <h5>Skapa ny sida</h5>
    </div>
    <div class="card-body">
        <EditForm Model="newPage" OnValidSubmit="CreatePageAsync" FormName="CreatePage">
            <DataAnnotationsValidator/>
            <ValidationSummary/>
            
            <div class="mb-3">
                <label class="form-label">Sidans titel</label>
                <InputText @bind-Value="newPage.Title" />
            </div>
            
            <div class="form-check form-switch mb-3">
                <InputCheckbox @bind-Value="newPage.IsPublished" class="form-check-input" id="publishCheck"/>
                <label class="form-check-label" for="publishCheck">Publicera sidan?</label>
            </div>

            <div class="form-check form-switch mb-3">
                <InputCheckbox @bind-Value="newPage.IsHomepage" class="form-check-input" id="homeCheck"/>
                <label class="form-check-label" for="homeCheck">Hemsida?</label>
            </div>
            
            <button type="submit" class="btn btn-primary">Skapa</button>
        </EditForm>
    </div>
</div>

<h3>Sidor</h3>

@if (pages == null)
{
    <p>Laddar...</p>
}
else if (pages.Count == 0)
{
    <p>Inga sidor ännu.</p>
}
else
{
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Befintliga sidor</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead>
                    <tr>
                        <th>Titel</th>
                        <th>URL</th>
                        <th>Publicerad</th>
                        <th>Hemsida</th>
                        <th>Skapad</th>
                        <th>Åtgärder</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in pages)
                    {
                        @if (item.Id == editingId)
                        {
                            <tr>
                                <td><input @bind="editPage.Title" class="form-control form-control-sm"/></td>
                                <td>@item.Url</td>
                                <td>
                                    <input type="checkbox" @bind="editPage.IsPublished" class="form-check-input"/>
                                </td>
                                <td>
                                    <input type="checkbox" @bind="editPage.IsHomepage" class="form-check-input"/>
                                </td>
                                <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <div class="d-grid gap-1">
                                        <button type="button" class="btn btn-success btn-sm" @onclick="SaveEditAsync">Spara</button>
                                        <button type="button" class="btn btn-secondary btn-sm" @onclick="CancelEdit">Avbryt</button>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            <tr>
                                <td>@item.Title</td>
                                <td>@item.Url</td>
                                <td>@(item.IsPublished ? "Ja" : "Nej")</td>
                                <td>@(item.IsHomepage ? "🟢" : "")</td>
                                <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <div class="d-grid gap-1">
                                        <button type="button" class="btn btn-warning btn-sm" @onclick="() => StartEdit(item)">Redigera</button>
                                        <button type="button" class="btn btn-danger btn-sm" @onclick="() => DeletePageAsync(item.Id)">Ta bort</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private HttpClient client = default!;
    
    private List<PageModel>? pages;

    [SupplyParameterFromForm]
    private CreatePageModel newPage { get; set; } = new();

    private int? editingId;
    private UpdatePageModel editPage = new();

    protected override async Task OnInitializedAsync()
    {
        client = HttpClientFactory.CreateClient("Api");
        await LoadPagesAsync();
    }

    private async Task LoadPagesAsync()
    {
        pages = await client.GetFromJsonAsync<List<PageModel>>("api/pages");
    }

    private async Task CreatePageAsync()
    {
        await client.PostAsJsonAsync("api/pages", newPage);
        newPage = new();
        await LoadPagesAsync();
    }

    private async Task DeletePageAsync(int id)
    {
        await client.DeleteAsync($"api/pages/{id}");
        await LoadPagesAsync();
    }

    private void StartEdit(PageModel item)      
    {                                                                                          
        editingId = item.Id;
        editPage.Title = item.Title;                                                           
        editPage.IsPublished = item.IsPublished;    
        editPage.IsHomepage = item.IsHomepage;
    }

    private void CancelEdit()
    {
        editingId = null;
    }

    private async Task SaveEditAsync()
    {
        await client.PutAsJsonAsync($"api/pages/{editingId}", editPage);
        editingId = null;
        await LoadPagesAsync();
    }

}
