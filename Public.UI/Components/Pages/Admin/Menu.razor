@page "/admin/menu"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject IHttpClientFactory HttpClientFactory
@rendermode InteractiveServer

<h3>Hantera meny</h3>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Skapa nytt menyval</h5>
    </div>
    <div class="card-body">
        <EditForm Model="newMenuItem" OnValidSubmit="CreateMenuItemAsync" FormName="MenuForm">
            <DataAnnotationsValidator/>
            <ValidationSummary class="text-danger"/>
            
            <div class="mb-3">
                <label class="form-label">Välj sida</label>
                <InputSelect @bind-Value="newMenuItem.PageId">
                    <option value="0">-- Välj sida --</option>
                    @if (pages != null)
                    {
                        @foreach (var p in pages)
                        {
                            <option value="@p.Id">@p.Title</option>
                        }
                    }
                </InputSelect>
            </div>
            
            <div class="mb-3">
                <label class="form-label">Rubrik</label>
                <InputText @bind-Value="newMenuItem.MenuTitle" class="form-control"/>
            </div>
            
            <div class="mb-3">
                <label class="form-label">Meny-ordning</label>
                <InputNumber @bind-Value="newMenuItem.Order" class="form-control"></InputNumber>
            </div>
            
            <button type="submit" class="btn btn-primary">Skapa</button>
            
        </EditForm>
    </div>
</div>

@if (menuItems == null)
{
    <p>Laddar...</p>
}
else if (menuItems.Count == 0)
{
    <p>Inget innehåll ännu.</p>
}
else
{
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Menyalternativ</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead>
                    <tr>
                        <th>Sida</th>
                        <th>Rubrik</th>
                        <th>Ordning</th>
                        <th>Åtgärder</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var menu in menuItems)
                    {
                        @if (menu.Id == editingId)
                        {
                            <tr>
                                <td>
                                    <select @bind="editMenuItem.PageId">
                                        @if (pages != null)
                                        {
                                            @foreach (var p in pages)
                                            {
                                                <option value="@p.Id">@p.Title</option>
                                            }
                                        }
                                    </select>
                                </td>
                                <td><input @bind="editMenuItem.MenuTitle"/></td>
                                <td><input @bind="editMenuItem.Order"/></td>
                                <td>
                                    <button type="button" class="btn btn-primary btn-sm" @onclick="SaveEditAsync">Spara</button>
                                    <button type="button" class="btn btn-danger btn-sm" @onclick="CancelEdit">Avbryt</button>
                                </td>
                            </tr>
                        }
                        else
                        {
                            <tr>
                                <td>@(pages?.FirstOrDefault(p => p.Id == menu.PageId)?.Title)</td>  
                                <td>@menu.MenuTitle</td>
                                <td>@menu.Order</td>
                                <td>
                                    <button type="button" class="btn btn-warning btn-sm" @onclick="() => StartEdit(menu)">Redigera</button>
                                    <button type="button" class="btn btn-danger btn-sm" @onclick="() => DeleteMenuItemAsync(menu.Id)">Ta bort</button>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private HttpClient client = default!;

    private List<MenuItemModel> menuItems;
    private List<PageModel>? pages;
    
    [SupplyParameterFromForm]
    private CreateMenuItemModel? newMenuItem { get; set; } = new();

    private int? editingId;
    private UpdateMenuItemModel editMenuItem = new();

    protected override async Task OnInitializedAsync()
    {
        client = HttpClientFactory.CreateClient("Api");
        await LoadMenuItemAsync();
        pages = await client.GetFromJsonAsync<List<PageModel>>("api/pages");
    }


    private async Task LoadMenuItemAsync()
    {
        menuItems = await client.GetFromJsonAsync<List<MenuItemModel>>("api/menuitems");
    }

    private async Task CreateMenuItemAsync()
    {
        await client.PostAsJsonAsync("api/menuitems", newMenuItem);
        newMenuItem = new CreateMenuItemModel(); // Nollställer formuläret med ett nytt tomt objekt
        await LoadMenuItemAsync();
    }

    private async Task DeleteMenuItemAsync(int id)
    {
        await client.DeleteAsync($"api/menuitems/{id}");
        await LoadMenuItemAsync();
    }
    
    private void StartEdit(MenuItemModel menuItem)      
    {                                                                                          
        editingId = menuItem.Id;
        editMenuItem.PageId = menuItem.PageId;
        editMenuItem.MenuTitle = menuItem.MenuTitle;
        editMenuItem.Order = menuItem.Order;
    }

    private void CancelEdit()
    {
        editingId = null;
    }

    private async Task SaveEditAsync()
    {
        await client.PutAsJsonAsync($"api/menuitems/{editingId}", editMenuItem);
        editingId = null;
        await LoadMenuItemAsync();
    }
}