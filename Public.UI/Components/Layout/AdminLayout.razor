@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<header class="bg-dark text-white py-3">
    <div class="container d-flex justify-content-between align-items-center">
        <a class="navbar-brand text-white text-decoration-none h4 m-0" href="/">Public - Admin</a>

        <div>
            <AuthorizeView>
                <Authorized>
                    <span class="me-3">Hej, @context.User.Identity?.Name!</span>
                    <form action="Account/Logout" method="post" class="d-inline">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="" />
                        <button type="submit" class="btn btn-outline-light btn-sm">Logga ut</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a class="btn btn-outline-light btn-sm" href="Account/Login">Logga in</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</header>

<nav class="bg-light border-bottom">
    <div class="container">
        <ul class="nav">
            <AuthorizeView Roles="Admin,Editor">
                <Authorized>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/content">Hantera innehåll</a>
                    </li>
                </Authorized>
            </AuthorizeView>
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/pages">Hantera sidor</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/menu">Hantera meny</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/visits">Statistik</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/users">Hantera användare</a>
                    </li>
                </Authorized>
            </AuthorizeView>
            <li class="nav-item ms-auto">
                <a class="nav-link" href="/">Tillbaka till sajten</a>
            </li>
        </ul>
    </div>
</nav>

<main class="container py-4">
    @Body
</main>
