@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject IHttpClientFactory HttpFactory

@if (activeStyle != null)
{
    <style>
          h1, h2, h3, h4, h5, h6 {
              color: @activeStyle.HeadingColor;
              font-family: @activeStyle.HeadingFont;
          }
          h1 { font-size: @(activeStyle.HeadingSize)px; }
          h2 { font-size: @(activeStyle.HeadingSize - 4)px; }
          h3 { font-size: @(activeStyle.HeadingSize - 8)px; }

          main p, main .content-block {
              color: @activeStyle.TextColor;
              font-family: @activeStyle.TextFont;
              font-size: @(activeStyle.TextSize)px;
          }

          main img {
              border-radius: @(activeStyle.ImageBorderRadius)px;
              border: 1px solid @activeStyle.ImageBorderColor;
          }

          main a {
              color: @activeStyle.LinkColor;
              text-decoration: @(activeStyle.LinkUnderline ?
                                   "underline" : "none");
          }
      </style>
}


<style>
    .nav-link:hover {
        background-color: var(--bs-warning);
        color: white;
    }
</style>

<header class="bg-warning text-white py-3">
    <div class="container">
        <a class="navbar-brand text-white text-decoration-none h4 m-0" href="/">Skrot & Korn</a>
    </div>
</header>

<nav class="bg-light border-bottom">
    <div class="container-fluid px-4">
        <ul class="nav d-flex flex-wrap justify-content-between align-items-center w-100">

            @* Vänster: menylänkar i en inre ul *@
            <li>
                <ul class="nav">
                    @if (menuItems != null)
                    {
                        @foreach (var item in menuItems)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/@item.Url">@item.MenuTitle</a>
                            </li>
                        }
                    }
                </ul>
            </li>

            @* Höger: login/logout beroende på inloggstatus *@
            <li>
                
                @* Visas endast om användaren är inloggad *@
                <AuthorizeView>
                    <Authorized>
                        <span class="me-3">Hej, @context.User.Identity?.Name!</span>

                        @* Admin-panel knapp, beroende på roll skickas man till olika admin-sidor *@
                        @* Sätter context-namnet till "adminContext" eftersom yttre AuthorizeView redan använder standardnamnet "context", detta för att undvika namnkonflikter*@
                        <AuthorizeView Roles="Admin" Context="adminContext">
                            <a href="/admin/pages" class="btn btn-outline-warning btn-sm me-3">Admin</a>
                        </AuthorizeView>
                        <AuthorizeView Roles="Editor" Context="editorContext">
                            <a href="/admin/content" class="btn btn-outline-warning btn-sm me-3">Admin</a>
                        </AuthorizeView>

                        <form action="Account/Logout" method="post" class="d-inline">

                            @* AntiforgeryToken är ett säkerhetskrav från Identitys logout-endpoint *@
                            <AntiforgeryToken/>

                            @* Dit användaren skickas efter den loggat ut, tom sträng = startsidan *@
                            <input type="hidden" name="ReturnUrl" value=""/>
                            <button type="submit" class="btn btn-outline-warning btn-sm">Logga ut</button>
                        </form>
                    </Authorized>

                    @* Visas endast om användarn ej är inloggad *@
                    <NotAuthorized>
                        <a class="btn btn-outline-dark btn-sm" href="Account/Login">Logga in</a>
                    </NotAuthorized>
                </AuthorizeView>
            </li>
                
        </ul>
    </div>
</nav>
  
<main class="container py-4">
    @Body
</main>   

@code {
    private List<MenuItemModel>? menuItems;
    private SiteStyleModel? activeStyle;
    
    protected override async Task OnInitializedAsync()
    {
        var client = HttpFactory.CreateClient("Api");
        menuItems = await client.GetFromJsonAsync<List<MenuItemModel>>("api/menuitems");

        try
        {
            activeStyle = await client.GetFromJsonAsync<SiteStyleModel>("api/sitestyles/active");
        }
        catch (System.Text.Json.JsonException)
        {
            // ifall det inte finns någon aktiv stil, ignorerar det, låt den vara null, då gäller Lux-temat istället
        }
    }
}

